SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional alias supported by code if you prefer this name in hosting dashboards.
SUPABASE_SERVICE_KEY=
GDELT_QUERY=(deepfake OR "synthetic media" OR "AI-generated" OR "voice clone")
GDELT_MAX_RECORDS=200
GDELT_CONTEXT_QUERY=((deepfake OR "synthetic media") AND (law OR regulation OR election OR algorithm OR teenager OR youth OR "social media" OR bias OR policy))
GDELT_CONTEXT_MAX_RECORDS=40
RSS_FEEDS=https://news.google.com/rss/search?q=deepfake+when:7d&hl=en-GB&gl=GB&ceid=GB:en,https://news.google.com/rss/search?q=deepfake+when:7d&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=%22voice+clone%22+when:7d&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=%22face+swap%22+when:7d&hl=en-US&gl=US&ceid=US:en,https://www.snopes.com/feed/,https://www.politifact.com/rss/all/,https://factcheck.afp.com/rss.xml,https://fullfact.org/feed/,https://leadstories.com/hoax-alert/rss.xml,https://www.bellingcat.com/feed/,https://medium.com/feed/dfrlab,https://euvsdisinfo.eu/feed/,https://www.ftc.gov/news-events/news/press-releases.xml,https://www.europol.europa.eu/rss.xml,https://www.wired.com/feed/rss,https://www.theregister.com/security/headlines.atom
RSS_MAX_ITEMS_PER_FEED=30
REDDIT_SUBREDDITS=deepfakes,MediaSynthesis,scams,OSINT,technology,news,worldnews
REDDIT_MAX_ITEMS_PER_SUBREDDIT=20
REDDIT_QUERY=(deepfake OR "ai fake" OR "voice clone" OR "synthetic media")
EXCLUDED_DOMAINS=womansworld.com,ibtimes.co.uk,thailand-business-news.com

# Optional detector integrations
HIVE_API_URL=
HIVE_API_KEY=
REALITY_DEFENDER_API_URL=
REALITY_DEFENDER_API_KEY=
DETECTION_TIMEOUT_MS=7000
DETECTION_MAX_ITEMS=20
